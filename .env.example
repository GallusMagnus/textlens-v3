# OPENAI_API_KEY: Required for TextLens analysis calls.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# TEXTLENS_MODEL: Optional override for the analysis model.
# Defaults to gpt-5.5 when unset.
TEXTLENS_MODEL="gpt-5.5"

# OPENAI_BASE_URL: Optional override for compatible gateways or proxies.
# Leave unset for the default OpenAI API.
OPENAI_BASE_URL=""

# VITE_WORKSPACE_PASSCODE: Custom passcode required to unlock the TextLens workspace.
# Set this explicitly in .env.local. There is no built-in default.
VITE_WORKSPACE_PASSCODE=
